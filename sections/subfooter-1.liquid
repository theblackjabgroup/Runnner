{% schema %}
{
  "name": "Localization Selector",
  "class": "shopify-section-localization",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "t:sections.all.colors.label", "default": "scheme-1" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "section_height", "label": "Section Height (px)", "min": 30, "max": 80, "step": 5, "default": 40 }
  ],
  "presets": [{ "name": "Localization Selector", "category": "Footer" }]
}
{% endschema %}

<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;700&display=swap" rel="stylesheet">

<style>
:root {
  --ff: 'Figtree', system-ui, -apple-system, "Segoe UI", Roboto, Arial;
  --subfooter-bg: #fff;
  --subfooter-border: rgba(0,0,0,.1);
  --subfooter-shadow: rgba(0,0,0,.1);
  --option-hover-bg: rgba(0,0,0,0.05);
}

.loc-subfooter {
  font-family: var(--ff);
  font-size: 11px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 20px;
  gap: 16px;
  width: 100%;
  box-sizing: border-box;
  text-transform: uppercase;
  background: var(--subfooter-bg);
}

.loc-left {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.loc-dropdown {
  position: relative;
}

.loc-toggle {
  all: unset;
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 6px;
  transition: background 0.2s ease;
}

.loc-toggle:hover {
  background: var(--option-hover-bg);
}

.flag-img {
  width: 18px;
  height: 12px;
  object-fit: cover;
  border-radius: 2px;
}

.caret {
  width: 12px;
  height: 12px;
  transition: transform .2s ease;
}

.loc-toggle[aria-expanded="true"] .caret {
  transform: rotate(180deg);
}

.loc-menu {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  background: var(--subfooter-bg);
  border: 1px solid var(--subfooter-border);
  border-radius: 8px;
  box-shadow: 0 4px 12px var(--subfooter-shadow);
  min-width: 200px;
  max-height: 250px;
  overflow-y: auto;
  display: none;
  z-index: 1000;
}

.loc-menu.open {
  display: block;
}

.loc-option {
  all: unset;
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 12px;
  cursor: pointer;
  font-size: 11px;
  border-radius: 6px;
  text-transform: uppercase;
  transition: background 0.2s ease;
}

.loc-option:hover,
.loc-option.selected {
  background: var(--option-hover-bg);
  font-weight: 600;
}

.opt-flag {
  width: 20px;
  height: 14px;
  object-fit: cover;
  border-radius: 2px;
}

.loc-center {
  flex: 1 1 auto;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 500;
}

.loc-payments {
  display: flex;
  gap: 12px;
  align-items: center;
}

@media (max-width: 749px) {
  .loc-subfooter {
    flex-direction: column;
    text-align: center;
    gap: 12px;
  }

  .loc-left,
  .loc-payments {
    justify-content: center;
    width: 100%;
  }

  .loc-center {
    order: -1;
  }
}
</style>

<div class="loc-subfooter" {{ section.shopify_attributes }}>

  <!-- LEFT: Country + Language -->
  <div class="loc-left">

    <!-- COUNTRY DROPDOWN -->
    {% form 'localization', id: 'FooterCountryForm' %}
      <div class="loc-dropdown">
        <button type="button" class="loc-toggle" aria-expanded="false">
          <img class="flag-img current-flag" src="https://flagcdn.com/15x9/{{ localization.country.iso_code | downcase }}.png" alt="{{ localization.country.name }}">
          <span>{{ localization.country.name | upcase }} ({{ localization.country.currency.iso_code | upcase }} {{ localization.country.currency.symbol }})</span>
          <svg class="caret" viewBox="0 0 12 8"><path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.4"/></svg>
        </button>

        <div class="loc-menu">
          {% for country in localization.available_countries %}
            <button type="button" class="loc-option" data-value="{{ country.iso_code }}">
              <img class="opt-flag" src="https://flagcdn.com/18x12/{{ country.iso_code | downcase }}.png" alt="{{ country.name }}">
              <span>{{ country.name | upcase }} ({{ country.currency.iso_code | upcase }} {{ country.currency.symbol }})</span>
            </button>
          {% endfor %}
        </div>
      </div>
    {% endform %}

    <!-- LANGUAGE DROPDOWN -->
    {% form 'localization', id: 'FooterLanguageForm' %}
      <div class="loc-dropdown">
        <button type="button" class="loc-toggle" aria-expanded="false">
          <span>{{ localization.language.endonym_name | upcase }}</span>
          <svg class="caret" viewBox="0 0 12 8"><path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.4"/></svg>
        </button>

        <div class="loc-menu">
          {% for lang in localization.available_languages %}
            <button type="button" class="loc-option" data-value="{{ lang.iso_code }}">
              <span>{{ lang.endonym_name | upcase }}</span>
            </button>
          {% endfor %}
        </div>
      </div>
    {% endform %}

  </div>

  <!-- CENTER -->
  <div class="loc-center">2025 - DELHI2 POWERED BY SHOPIFY</div>

  <!-- PAYMENTS RIGHT -->
  <div class="loc-payments">
    {% for type in shop.enabled_payment_types %}
      {% assign t = type | downcase %}
      {% if t contains 'visa' %}<span aria-hidden="true">{{ type | payment_type_svg_tag: class: 'pay-visa' }}</span>{% endif %}
      {% if t contains 'master' %}<span aria-hidden="true">{{ type | payment_type_svg_tag: class: 'pay-master' }}</span>{% endif %}
      {% if t contains 'paypal' %}<span aria-hidden="true">{{ type | payment_type_svg_tag: class: 'pay-paypal' }}</span>{% endif %}
    {% endfor %}
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.loc-dropdown').forEach(drop => {
    const toggle = drop.querySelector('.loc-toggle');
    const menu = drop.querySelector('.loc-menu');
    const form = drop.closest('form');

    // Toggle dropdown
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = menu.classList.contains('open');
      document.querySelectorAll('.loc-menu.open').forEach(m => m.classList.remove('open'));
      document.querySelectorAll('.loc-toggle[aria-expanded="true"]').forEach(t => t.setAttribute('aria-expanded','false'));
      if(!isOpen){
        menu.classList.add('open');
        toggle.setAttribute('aria-expanded','true');
      }
    });

    // Option click → submit form
    menu.querySelectorAll('.loc-option').forEach(opt => {
      opt.addEventListener('click', () => {
        const value = opt.getAttribute('data-value');
        const name = form.querySelector('input[name=country_code]') ? 'country_code' : 'language_code';
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = name;
        input.value = value;
        form.appendChild(input);
        form.submit();
      });
    });
  });

  // Click outside closes dropdown
  document.addEventListener('click', (e) => {
    if(!e.target.closest('.loc-dropdown')){
      document.querySelectorAll('.loc-menu.open').forEach(m => m.classList.remove('open'));
      document.querySelectorAll('.loc-toggle[aria-expanded="true"]').forEach(t => t.setAttribute('aria-expanded','false'));
    }
  });
});
</script>
